# User Order Service base URL (see API_DOCUMENTATION-USER-ORDER.md).
# Local backend default is http://localhost:5003 — set this to your deployed
# domain in production. Copy this file to `.env` and adjust as needed.
VITE_USER_ORDER_API_BASE_URL=http://localhost:5003

# Public origin of the site, no trailing slash. Used for canonical URLs, og:url
# and JSON-LD @ids. MUST be set to the real production domain before deploying:
# a canonical pointing at the wrong host tells search engines the live pages are
# duplicates of a domain that doesn't exist, and they will not be indexed.
# The same domain must also be substituted into public/robots.txt,
# public/sitemap.xml and the absolute URLs in index.html.
VITE_SITE_URL=https://jupyterlabs.example.com
